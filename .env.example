# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeThisToASecurePassword
POSTGRES_DB=worldcup
DATABASE_URL=postgresql://postgres:ChangeThisToASecurePassword@db:5432/worldcup?sslmode=disable

# Cache Configuration
REDIS_URL=redis://redis:6379/0

# Security, CORS & JWT
# Secret key for JWT signing. Generate a secure random string (e.g. using `openssl rand -hex 32`)
SECRET_KEY=unsafe_default_secret_key_change_me_in_prod_using_random_hex
CORS_ALLOWED_ORIGINS=http://localhost:8083
SITE_URL=http://localhost:8083

# External APIs
# Optional: API-Football key (kept for legacy sync, not actively used by Wikipedia scraper)
SPORTS_API_KEY=your_sports_api_key_here
# Optional: Resend API key for sending email digests and password resets
TRANS_EMAIL_API_KEY=your_resend_api_key_here
# Optional: Webhook validation secret for Resend
RESEND_WEBHOOK_SECRET=

# Diagnostics / Debugging
# Set to true to enable diagnostic endpoints. NEVER use in production.
DEBUG=false

# Platform Config overrides
# Optional: Override the ISO timestamp when the tournament lock occurs (e.g. "2026-06-11T13:45:00Z")
TOURNAMENT_LOCK_AT=
# Daily limit on the number of digest emails sent
MAX_DIGEST_EMAILS_PER_DAY=100
